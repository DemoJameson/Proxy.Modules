{
    "id": "demojameson.app.sub",
    "name": "DemoJameson 应用订阅",
    "description": "DemoJameson 的 BoxJs 订阅",
    "author": "@DemoJameson",
    "repo": "https://github.com/DemoJameson/Proxy.Modules",
    "icon": "https://avatars.githubusercontent.com/u/181192?v=4",
    "apps": [
        {
            "id": "demojameson_trakt_simplified_chinese",
            "name": "Trakt 增强",
            "keys": [
                "@dj_trakt_boxjs_configs.posterImageMode",
                "@dj_trakt_boxjs_configs.historyEpisodesMergedByShow",
                "@dj_trakt_boxjs_configs.googleTranslationEnabled",
                "@dj_trakt_boxjs_configs.characterTranslationEnabled",
                "@dj_trakt_boxjs_configs.eplayerxEnabled",
                "@dj_trakt_boxjs_configs.forwardEnabled",
                "@dj_trakt_boxjs_configs.infuseEnabled",
                "@dj_trakt_boxjs_configs.useShortcutsJumpEnabled",
                "@dj_trakt_boxjs_configs.backendBaseUrl",
                "@dj_trakt_boxjs_configs.debugEnabled"
            ],
            "author": "@DemoJameson",
            "repo": "https://github.com/DemoJameson/Proxy.Modules/tree/main/trakt_simplified_chinese",
            "icons": [
                "https://raw.githubusercontent.com/DemoJameson/Proxy.Modules/main/trakt_simplified_chinese/images/trakt.webp",
                "https://raw.githubusercontent.com/DemoJameson/Proxy.Modules/main/trakt_simplified_chinese/images/trakt.webp"
            ],
            "settings": [
                {
                    "id": "@dj_trakt_boxjs_configs.posterImageMode",
                    "name": "海报语言",
                    "val": "original",
                    "type": "select",
                    "desc": "原片语言使用 TMDb 影片原始语言图片；中文使用 TMDb 中文图片；原图保留 Trakt 原图",
                    "items": [
                        {
                            "key": "original",
                            "label": "原片语言"
                        },
                        {
                            "key": "chinese",
                            "label": "中文"
                        },
                        {
                            "key": "default",
                            "label": "原图"
                        }
                    ]
                },
                {
                    "id": "@dj_trakt_boxjs_configs.historyEpisodesMergedByShow",
                    "name": "历史剧集按电视剧合并",
                    "val": true,
                    "type": "boolean",
                    "desc": "启用后会将历史页面电视剧类别的观看记录按电视剧合并"
                },
                {
                    "id": "@dj_trakt_boxjs_configs.googleTranslationEnabled",
                    "name": "用谷歌翻译部分文本",
                    "val": true,
                    "type": "boolean",
                    "desc": "启用后会翻译评论、社区情绪、冷知识、演员、片单等谷歌翻译场景"
                },
                {
                    "id": "@dj_trakt_boxjs_configs.characterTranslationEnabled",
                    "name": "用豆瓣翻译角色名",
                    "val": true,
                    "type": "boolean",
                    "desc": "启用后会用豆瓣翻译角色名"
                },
                {
                    "id": "@dj_trakt_boxjs_configs.eplayerxEnabled",
                    "name": "EplayerX 跳转按钮",
                    "val": true,
                    "type": "boolean",
                    "desc": "启用后在 Trakt 和 SofaTime 中添加 EplayerX 跳转按钮"
                },
                {
                    "id": "@dj_trakt_boxjs_configs.forwardEnabled",
                    "name": "Forward 跳转按钮",
                    "val": true,
                    "type": "boolean",
                    "desc": "启用后在 Trakt 和 SofaTime 中添加 Forward 跳转按钮"
                },
                {
                    "id": "@dj_trakt_boxjs_configs.infuseEnabled",
                    "name": "Infuse 跳转按钮",
                    "val": true,
                    "type": "boolean",
                    "desc": "启用后在 Trakt 和 SofaTime 中添加 Infuse 跳转按钮"
                },
                {
                    "id": "@dj_trakt_boxjs_configs.useShortcutsJumpEnabled",
                    "name": "借助快捷指令跳转",
                    "val": false,
                    "type": "boolean",
                    "desc": "启用后播放器跳转链接改为通过快捷指令打开 DeepLink，用于规避弹框确认。Safari浏览器需处于非无痕模式，配置快捷指令 https://www.icloud.com/shortcuts/9238bef05b144159a4351c2fa9e2570d"
                },
                {
                    "id": "@dj_trakt_boxjs_configs.backendBaseUrl",
                    "name": "翻译缓存接口",
                    "val": "https://proxy-modules.demojameson.de5.net",
                    "type": "text",
                    "desc": "用于批量获取 Trakt 的中文翻译，一般留空即可"
                },
                {
                    "id": "@dj_trakt_boxjs_configs.debugEnabled",
                    "name": "调试模式",
                    "val": false,
                    "type": "boolean",
                    "desc": "启用后每次都会刷新 translation-overrides 覆盖数据"
                }
            ],
            "descs_html": [
                "Trakt App 各页面从英文改为简体中文，支持中文标题、简介和海报；历史页面剧集类别的已观看记录按电视剧合并；Trakt 和 SofaTime 的影片详情页添加 EplayerX、Forward、Infuse 跳转按钮；部分兼容其它使用了 Trakt API 的应用。",
                "点此直达 <a href=\"https://github.com/DemoJameson/Proxy.Modules/tree/main/trakt_simplified_chinese\">项目目录</a>",
                "Egern 安装：<a href=\"egern:/modules/new?name=%E4%BC%98%E5%8C%96%20Trakt%20%E7%AE%80%E4%BD%93%E4%B8%AD%E6%96%87%E4%BD%93%E9%AA%8C&amp;url=https%3A%2F%2Fraw.githubusercontent.com%2FDemoJameson%2FProxy.Modules%2Fmain%2Ftrakt_simplified_chinese%2Ftrakt_simplified_chinese.plugin\">安装模块</a>",
                "Loon 安装：<a href=\"https://www.nsloon.com/openloon/import?plugin=https%3A%2F%2Fraw.githubusercontent.com%2FDemoJameson%2FProxy.Modules%2Fmain%2Ftrakt_simplified_chinese%2Ftrakt_simplified_chinese.plugin\">安装插件</a>",
                "Surge 安装：<a href=\"surge:///install-module?url=https%3A%2F%2Fraw.githubusercontent.com%2FDemoJameson%2FProxy.Modules%2Fmain%2Ftrakt_simplified_chinese%2Ftrakt_simplified_chinese.sgmodule\">安装模块</a>",
                "QX 安装：<a href=\"https://quantumult.app/x/open-app/add-resource?remote-resource=%7B%22rewrite_remote%22%3A%5B%22https%3A%2F%2Fraw.githubusercontent.com%2FDemoJameson%2FProxy.Modules%2Fmain%2Ftrakt_simplified_chinese%2Ftrakt_simplified_chinese.snippet%2C%20tag%3DTrakt%20Simplified%20Chinese%2C%20enabled%3Dtrue%22%5D%7D\">安装片段</a>",
                "配套快捷指令：<a href=\"https://www.icloud.com/shortcuts/9238bef05b144159a4351c2fa9e2570d\">打开链接</a>",
                "脚本读取优先级：默认值 < BoxJs < 插件参数。已经在插件参数里填写的值会覆盖 BoxJs。"
            ]
        }
    ]
}
